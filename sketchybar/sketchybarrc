           --add item slack.ch1 popup.slack \
           --add item slack.ch2 popup.slack \
           --add item slack.ch3 popup.slack \
           --add item slack.ch4 popup.slack \
           --add item slack.ch5 popup.slack

# Bluetooth: Spiritweb
sketchybar --add item bluetooth right \
           --set bluetooth update_freq=60 \
                           padding_left=8 \
                           padding_right=8 \
                           script="$PLUGIN_DIR/hover.sh $PLUGIN_DIR/bluetooth.sh" \
                           click_script="$PLUGIN_DIR/bluetooth.sh click" \
                           popup.align=right \
           --subscribe bluetooth mouse.entered mouse.exited



# Battery: Stormlight Reserve
sketchybar --add item battery right \
           --set battery update_freq=120 \
                         padding_left=8 \
                         padding_right=8 \
                         script="$PLUGIN_DIR/hover.sh $PLUGIN_DIR/battery.sh" \
                         popup.align=right \
                         popup.y_offset=12 \
           --subscribe battery power_source_change system_woke mouse.entered mouse.exited \
  \
           --add bracket system.pill battery bluetooth control_center \
           --set system.pill background.color=$BAR_COLOR \
                             background.border_color=$PRES_GLACIAL_TRANSLUCENT \
                             background.border_width=1 \
                             background.corner_radius=10 \
                             background.drawing=on \
  \
           --add item battery.status popup.battery \
           --set battery.status icon=󰁹 \
                                icon.color=$BATT_ACCENT \
                                label.color=$WHITE \
                                label.font="JetBrainsMono Nerd Font:Bold:14.0"



# Clock: Chronicles
sketchybar --add item clock right \
           --set clock update_freq=30 script="$PLUGIN_DIR/hover.sh $PLUGIN_DIR/clock.sh" click_script="$PLUGIN_DIR/clock_click.sh" icon=󰃭 \
           --subscribe clock mouse.entered mouse.exited \
           popup.align=right \
  \
  --add item clock.header popup.clock \
    --set clock.header icon=󰃤 label="CHRONICLES" label.font="JetBrainsMono Nerd Font:Bold:14.0" label.color=$CLOCK_ACCENT icon.color=$CLOCK_ACCENT \
  \
  --add item clock.date popup.clock --set clock.date icon=󰃭 label="Chronicle Loading..." \
  --add item clock.events popup.clock --set clock.events label="Destiny" \
  --add item clock.weather1 popup.clock --set clock.weather1 icon= script="$PLUGIN_DIR/weather.sh" \
  --add item clock.temperature popup.clock --set clock.temperature icon= script="$PLUGIN_DIR/weatherTemp.sh"

# Calendar Lines (Optional monthly calendar on click)
for i in {1..8}
do
  sketchybar --add item clock.calendar.line.$i popup.clock \
             --set clock.calendar.line.$i drawing=off \
                                         label.font="Courier:Bold:12.0" \
                                         label.color=$WHITE \
                                         icon.drawing=off \
                                         padding_left=20
done

sketchybar --add bracket clock.pill clock \
           --set clock.pill background.color=$BAR_COLOR \
                            background.border_color=$CLOCK_ACCENT_T \
                            background.border_width=1 \
                            background.corner_radius=10 \
                            background.drawing=on


